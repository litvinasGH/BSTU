<Window x:Class="Lab8Crypto.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RSA и Эль-Гамаль"
        Height="750"
        Width="1100"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">

        <TabControl>

            <!-- RSA -->
            <TabItem Header="RSA">

                <ScrollViewer>

                    <StackPanel Margin="10">

                        <TextBlock Text="RSA"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Margin="0,0,0,20"/>

                        <WrapPanel Margin="0,0,0,20">

                            <Button Content="Сгенерировать ключи"
                                    Width="220"
                                    Height="40"
                                    Margin="0,0,10,0"
                                    Click="GenerateRSAKeys_Click"/>

                            <Button Content="Зашифровать"
                                    Width="160"
                                    Height="40"
                                    Margin="0,0,10,0"
                                    Click="EncryptRSA_Click"/>

                            <Button Content="Расшифровать"
                                    Width="160"
                                    Height="40"
                                    Click="DecryptRSA_Click"/>

                        </WrapPanel>

                        <TextBlock Text="Исходный текст"/>
                        <TextBox x:Name="RsaInputBox"
                                 Height="80"
                                 FontSize="16"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 Margin="0,5,0,15"/>

                        <TextBlock Text="Шифротекст (Base64)"/>
                        <TextBox x:Name="RsaEncryptedBox"
                                 Height="180"
                                 FontFamily="Consolas"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 Margin="0,5,0,15"/>

                        <TextBlock Text="Расшифрованный текст"/>
                        <TextBox x:Name="RsaDecryptedBox"
                                 Height="80"
                                 FontSize="16"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 Margin="0,5,0,15"/>

                        <TextBlock Text="Время выполнения"/>
                        <TextBox x:Name="RsaTimeBox"
                                 Height="40"
                                 FontSize="16"/>

                    </StackPanel>

                </ScrollViewer>

            </TabItem>

            <!-- Эль-Гамаль -->
            <TabItem Header="Эль-Гамаль">

                <ScrollViewer>

                    <StackPanel Margin="10">

                        <TextBlock Text="Эль-Гамаль"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Margin="0,0,0,20"/>

                        <WrapPanel Margin="0,0,0,20">

                            <Button Content="Сгенерировать ключи"
                                    Width="220"
                                    Height="40"
                                    Margin="0,0,10,0"
                                    Click="GenerateElGamalKeys_Click"/>

                            <Button Content="Зашифровать"
                                    Width="160"
                                    Height="40"
                                    Margin="0,0,10,0"
                                    Click="EncryptElGamal_Click"/>

                            <Button Content="Расшифровать"
                                    Width="160"
                                    Height="40"
                                    Click="DecryptElGamal_Click"/>

                        </WrapPanel>

                        <TextBlock Text="Исходный текст"/>
                        <TextBox x:Name="ElInputBox"
                                 Height="80"
                                 FontSize="16"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 Margin="0,5,0,15"/>

                        <TextBlock Text="Шифротекст (Base64)"/>
                        <TextBox x:Name="ElEncryptedBox"
                                 Height="180"
                                 FontFamily="Consolas"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 Margin="0,5,0,15"/>

                        <TextBlock Text="Расшифрованный текст"/>
                        <TextBox x:Name="ElDecryptedBox"
                                 Height="80"
                                 FontSize="16"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 Margin="0,5,0,15"/>

                        <TextBlock Text="Время выполнения"/>
                        <TextBox x:Name="ElTimeBox"
                                 Height="40"
                                 FontSize="16"/>

                    </StackPanel>

                </ScrollViewer>

            </TabItem>

        </TabControl>

    </Grid>
</Window>
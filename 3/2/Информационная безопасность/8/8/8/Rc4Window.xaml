<Window x:Class="_8.Rc4Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_8"
        mc:Ignorable="d"
        Title="Rc4Window" Height="450" Width="800">
    <Grid Margin="12">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="Загрузить файл" Width="130" Height="32" Margin="0,0,8,0" Click="LoadFile_Click"/>
                <Button Content="Зашифровать" Width="110" Height="32" Margin="0,0,8,0" Click="Encrypt_Click"/>
                <Button Content="Расшифровать" Width="120" Height="32" Margin="0,0,8,0" Click="Decrypt_Click"/>
                <Button Content="Сохранить результат" Width="160" Height="32" Click="SaveResult_Click"/>
            </StackPanel>

            <TextBlock Text="Входное поле (текст или Base64-шифртекст)" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBox x:Name="InputText"
                     Height="120"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     TextChanged="InputText_TextChanged"/>

            <TextBlock Text="Результат" FontWeight="Bold" Margin="0,10,0,4"/>
            <TextBox x:Name="OutputText"
                     Height="120"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     IsReadOnly="True"/>

            <ProgressBar x:Name="ProgressBar" Height="20" Minimum="0" Maximum="100" Margin="0,12,0,0"/>

            <TextBlock x:Name="InputInfoText" Margin="0,10,0,0"/>
            <TextBlock x:Name="PlainInfoText" Margin="0,4,0,0"/>
            <TextBlock x:Name="CipherInfoText" Margin="0,4,0,0"/>
            <TextBlock x:Name="TimeText" Margin="0,8,0,0" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>

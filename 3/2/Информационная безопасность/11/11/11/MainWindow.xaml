<Window x:Class="HashApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MD Hash" Height="350" Width="600">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <Button Name="btnOpen"
                    Width="120"
                    Height="30"
                    Margin="0,0,10,0"
                    Click="btnOpen_Click">
                Выбрать файл
            </Button>

            <Button Name="btnHash"
                    Width="140"
                    Height="30"
                    Margin="10,0,0,0"
                    Click="btnHash_Click">
                Вычислить
            </Button>
        </StackPanel>

        <TextBlock Name="tbFile"
                   Grid.Row="1"
                   Margin="0,10,0,10"
                   FontSize="14"/>

        <TextBox Name="tbResult"
                 Grid.Row="2"
                 FontFamily="Consolas"
                 FontSize="16"
                 IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto"
                 TextWrapping="Wrap"/>
    </Grid>
</Window>